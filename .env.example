# ---------------------------------------------------------------------------
# Helios Solar — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Anything prefixed NEXT_PUBLIC_ is exposed to the browser — keep secrets unprefixed.
# ---------------------------------------------------------------------------

# Canonical site URL (used for metadata, OG, sitemap, robots, canonical tags)
NEXT_PUBLIC_SITE_URL=https://helios-solar.example.com

# --- Lead form delivery (Phase 4) -----------------------------------------
# Transactional email provider API key (e.g. Resend). Server-side only.
RESEND_API_KEY=
# Inbox that receives new leads.
LEADS_TO_EMAIL=leads@heliossolar.example.com
# Verified "from" address.
LEADS_FROM_EMAIL=website@heliossolar.example.com

# --- Spam protection / CAPTCHA (Phase 4) ----------------------------------
# Cloudflare Turnstile. Leave blank to disable the CAPTCHA gate.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- Rate limiting (Phase 4, optional distributed limiter) -----------------
# Upstash Redis REST credentials. If unset, an in-memory limiter is used.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Analytics (Phase 5, cookieless by default) ----------------------------
# Plausible domain, e.g. heliossolar.com. Leave blank to disable analytics.
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
